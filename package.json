{
  "name": "roomos-macro-simulator",
  "version": "1.0.0",
  "description": "single-page application for experimenting with Cisco RoomOS-style macros without needing physical hardware or a backend service",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "screenshot:readme": "tsx scripts/capture-readme-screenshot.mts",
    "test:e2e:install": "playwright install",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@momentum-design/brand-visuals": "^0.33.0",
    "@momentum-design/fonts": "^0.2.5",
    "@momentum-design/icons": "^0.54.0",
    "@momentum-design/tokens": "^0.10.2",
    "@playwright/test": "^1.53.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.3"
  },
  "keywords": [
    "roomos",
    "macros",
    "collaboration"
  ],
  "author": "William Mills",
  "license": "MIT",
  "dependencies": {
    "monaco-editor": "^0.52.0"
  }
}
